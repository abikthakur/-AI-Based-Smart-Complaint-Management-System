    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Water pipeline damaged\",\n    \"description\": \"There is a huge leak in the main water pipeline near the central market.\",\n    \"category\": \"Water\",\n    \"location\": \"Central Market, Ghaziabad\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/complaints",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "complaints"
              ]
            }
          }
        },
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/complaints",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "complaints"
              ]
            }
          }
        },
        {
          "name": "Update Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"In Progress\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/complaints/COMPLAINT_ID",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "complaints",
                "COMPLAINT_ID"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
